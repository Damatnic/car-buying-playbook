# Cloud sync (optional - enables cross-device auto-sync)
# Provision Vercel KV in your Vercel project (Storage > Create > KV).
# Vercel will inject these automatically on deploy. For local dev, copy from
# vercel env pull .env.development.local

KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
